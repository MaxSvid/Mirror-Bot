# Telegram Bot
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# PostgreSQL (used by both the bot and the postgres container)
POSTGRES_USER=mirror_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mirror_bot_db
POSTGRES_HOST=postgres          # service name inside docker-compose network
POSTGRES_PORT=5432              # internal port inside the container
PGDATA=/var/lib/postgresql/data

# Host port Docker binds postgres to on the VPS (must differ from scholar's 5432)
# pgAdmin will connect to the VPS on THIS port
POSTGRES_PORT_HOST=5434
